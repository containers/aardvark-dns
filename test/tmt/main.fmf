/validate:
    summary: Validate test
    test: make -C ../.. validate
    require:
        - clippy
        - rustfmt
    adjust:
        enabled: false
        when: initiator is not defined or initiator != packit

/unit:
    summary: Unit tests
    test: make -C ../.. unit
    require:
        - cargo
    adjust:
        enabled: false
        when: initiator is not defined or initiator != packit

/integration:
    summary: Integration tests
    test: bash test_integration.sh
    environment:
        AARDVARK: /usr/libexec/podman/aardvark-dns
    require:
        - aardvark-dns-tests
    adjust:
        duration: 10m
        when: arch == aarch64
